{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Bagl",
  "scopeName": "source.bagl",
  "patterns": [
    { "include": "#comments" },
    { "include": "#keywords" },
    { "include": "#constants" },
    { "include": "#types" },
    { "include": "#tensor-ops" },
    { "include": "#strings" },
    { "include": "#numbers" },
    { "include": "#operators" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.bagl",
          "match": "//.*$"
        },
        {
          "name": "comment.block.bagl",
          "begin": "/\\*",
          "end": "\\*/"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.bagl",
          "match": "\\b(if|then|else)\\b"
        },
        {
          "name": "keyword.other.bagl",
          "match": "\\b(let|letrec|in|fn)\\b"
        }
      ]
    },
    "constants": {
      "patterns": [
        {
          "name": "constant.language.boolean.bagl",
          "match": "\\b(true|false)\\b"
        }
      ]
    },
    "types": {
      "patterns": [
        {
          "name": "storage.type.bagl",
          "match": "\\b(int|float|bool|string|tensor)\\b"
        }
      ]
    },
    "tensor-ops": {
      "patterns": [
        {
          "name": "support.function.tensor.bagl",
          "match": "\\b(dot|transpose|reshape|grad)\\b"
        }
      ]
    },
    "strings": {
      "name": "string.quoted.double.bagl",
      "begin": "\"",
      "end": "\"",
      "patterns": [
        {
          "name": "constant.character.escape.bagl",
          "match": "\\\\."
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.float.bagl",
          "match": "\\b[0-9]+\\.[0-9]+\\b"
        },
        {
          "name": "constant.numeric.integer.bagl",
          "match": "\\b[0-9]+\\b"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.bagl",
          "match": "->|==|!=|<=|>=|[-+*/<>=!]"
        }
      ]
    }
  }
}
